# Base URL of the API server (no trailing slash). The RTK base query appends
# `/api` to this value, so point it at the server root.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Public site URL used for canonical links, sitemap and Open Graph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Host that serves uploaded media (`/uploads/...`). Usually the same as the
# API server root. Used by the editor to build absolute image/file URLs.
NEXT_PUBLIC_IMAGE_URL=http://localhost:5000

# Optional: comma-separated legacy media hosts to rewrite to relative paths in
# stored editor HTML (e.g. http://old-host:5000,https://old.cdn.example.com).
NEXT_PUBLIC_LEGACY_IMAGE_HOSTS=
